      "onClick": "{{\n  getDetalleOrden.run().then(() => {\n    if (getDetalleOrden.data && getDetalleOrden.data.length > 0) {\n    \n      storeValue('orden_editable', getDetalleOrden.data[0])\n      storeValue('items_editables', getDetalleOrden.data[0].items || [])\n      \n      Promise.all([\n        getTerritoriosFiltro.run(),\n        getProductosPorLaboratorio.run({ \n          id_laboratorio: Number(getDetalleOrden.data[0].laboratorio_id) \n        }),\n\t\t\t\tgetFacturasSTL.run(),\n  getFacturasLAB.run()\n      ]).then(() => {\n        \n              resetWidget(\"items_table_modal\", true)\n              showModal('mdl_detalle_orden')\n      })\n      \n    } else {\n      showAlert('La consulta no devolvió ninguna orden.', 'warning')\n    }\n  }).catch((err) => {\n    showAlert('Error al cargar el detalle de la orden: ' + err.message, 'error')\n  })\n}}",
