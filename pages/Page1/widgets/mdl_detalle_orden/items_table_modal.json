      "notation": "standard",
      "onClick": "{{\n  // Accedemos directamente a la fila usando el índice disparado sobre los datos actuales de la tabla\n  !items_table_modal.tableData[items_table_modal.triggeredRowIndex]?.id_detalle_op \n    ? \n      // CASO A: Es una fila nueva (no tiene id_detalle_op en la base de datos)\n      storeValue(\n        'items_editables', \n        (appsmith.store.items_editables || []).filter((item, index) => index !== items_table_modal.triggeredRowIndex)\n      ).then(() => {\n        // Forzamos el reseteo para limpiar estados visuales residuales\n        resetWidget(\"items_table_modal\", true);\n        showAlert('Fila provisional eliminada', 'info');\n      })\n    : \n      // CASO B: La fila ya existe en Supabase\n      showAlert('Esta fila ya está guardada en la base de datos y no se puede eliminar localmente.', 'warning')\n}}",
