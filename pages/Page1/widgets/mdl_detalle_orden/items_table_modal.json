      "label": "Save / Discard",
      "notation": "standard",
      "onSave": "{{\n  (function() {\n    const oldItems = appsmith.store.items_editables || [];\n    const newItems = [...oldItems];\n    let updatedRowData = items_table_modal.updatedRow;\n    \n    // Limpiar formato de miles en cantidad (si es string con puntos)\n    if (updatedRowData.cantidad && typeof updatedRowData.cantidad === 'string') {\n      updatedRowData.cantidad = parseInt(updatedRowData.cantidad.replace(/\\./g, ''), 10);\n    }\n    \n    // Buscar por id_temporal (prioritario) o id_detalle_op (para filas existentes)\n    const rowIndex = newItems.findIndex(item => \n      (updatedRowData.id_temporal && item.id_temporal === updatedRowData.id_temporal) ||\n      (updatedRowData.id_detalle_op && item.id_detalle_op === updatedRowData.id_detalle_op)\n    );\n    \n    if (rowIndex !== -1) {\n      // Conservar el id_temporal original si la fila lo tenía\n      const finalRow = { ...updatedRowData };\n      if (newItems[rowIndex].id_temporal && !finalRow.id_temporal) {\n        finalRow.id_temporal = newItems[rowIndex].id_temporal;\n      }\n      newItems[rowIndex] = finalRow;\n      storeValue('items_editables', newItems);\n      showAlert('Cambios guardados correctamente', 'success');\n    } else {\n      showAlert('No se pudo encontrar la fila editada', 'error');\n    }\n  })()\n}}",
      "originalId": "EditActions1",
      "saveActionLabel": "Save",
      "saveBorderRadius": "{{items_table_modal.processedTableData.map((currentRow, currentIndex) => ( (appsmith.theme.borderRadius.appBorderRadius)))}}",
